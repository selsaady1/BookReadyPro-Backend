# BookReadyPro backend environment variables (set these on Render; never commit real values)

# --- Database (Neon Postgres) ---
database_user=
database_password=
database_host=
database_name=
NODE_ENV=production

# --- Background worker / Python Excel service ---
excel_processing_endpoint=   # URL of the Python service (Render) that produces the workbooks

# --- File storage (Vercel Blob, S3-compatible) ---
SYNTHEIA_STORAGE_BUCKET=     # Blob store / bucket name
BLOB_S3_ENDPOINT=            # Vercel Blob S3-compatible endpoint
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# --- App ---
PORT=                        # injected by Render automatically
CORS_ORIGIN=https://qnowconsulting.com
SESSION_SECRET=              # random long string

# --- Stripe (DORMANT until billing is turned on; rotate the old exposed keys first) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
FRONTEND_ORIGIN=https://qnowconsulting.com
